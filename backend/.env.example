# ============================================================
# 本地配置文件，不要提交到仓库。
# 复制此文件为 .env 并填入真实值。
# ============================================================

# ---- LLM 大语言模型 ----
# LLM 服务商类型（如 openai）
LLM_PROVIDER=openai
# 模型名称
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
# API 接口地址
LLM_BASE_URL=https://api.siliconflow.cn/v1
# 请求超时（秒）
LLM_TIMEOUT_SECONDS=200
# API 密钥
OPENAI_API_KEY=xxx

# ---- Unsplash 图片 ----
# Unsplash API 访问密钥（用于获取景点图片）
UNSPLASH_ACCESS_KEY=xxx

# ---- 高德地图 ----
# Web 服务 API 密钥（地理编码、路线规划）
AMAP_WEB_SERVICE_KEY=xxx
# MCP API 密钥（用于高德 MCP Agent）
AMAP_MCP_KEY=xxx
# JS API 密钥（前端地图展示）
AMAP_JS_API_KEY=xxx
# JS API 安全密钥（前端安全校验）
AMAP_JS_SECURITY_CODE=xxx